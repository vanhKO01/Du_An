<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/white">

        <!-- Spinner category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Tên danh mục"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

        </LinearLayout>

        <!-- Code (readonly when editing) -->
        <TextView
            android:id="@+id/tv_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/gray"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <!-- Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Tên SP"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <EditText
                android:id="@+id/et_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập tên sản phẩm"
                android:background="@null"
                android:textSize="13sp"
                android:inputType="text"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Giá SP"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <EditText
                android:id="@+id/et_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập giá sản phẩm"
                android:background="@null"
                android:textSize="13sp"
                android:inputType="numberDecimal"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Quantity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Số lượng"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <EditText
                android:id="@+id/et_quantity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập số lượng"
                android:background="@null"
                android:textSize="13sp"
                android:inputType="number"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Unit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Đơn vị tính"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <EditText
                android:id="@+id/et_unit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập đơn vị tính"
                android:background="@null"
                android:textSize="13sp"
                android:inputType="text"/>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Import Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Ngày nhập"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <EditText
                android:id="@+id/et_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nhập ngày nhập"
                android:background="@null"
                android:textSize="13sp"
                android:inputType="text"/>

        </LinearLayout>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Lưu"
            android:textAllCaps="false"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Hủy"
            android:textAllCaps="false"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>
