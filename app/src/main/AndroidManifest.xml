<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.jpmart">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="JPMart"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JPMart">

        <activity android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.HomeManagerActivity" android:exported="false"/>
        <activity android:name=".activities.HomeStaffActivity" android:exported="false"/>
        <activity android:name=".activities.CategoryActivity" android:exported="false"/>
        <activity android:name=".activities.ProductActivity" android:exported="false"/>
        <activity android:name=".activities.CustomerActivity" android:exported="false"/>
        <activity android:name=".activities.InvoiceActivity" android:exported="false"/>
        <activity android:name=".activities.InvoiceDetailActivity" android:exported="false"/>
        <activity android:name=".activities.CartActivity" android:exported="false"/>
        <activity android:name=".activities.StaffActivity" android:exported="false"/>
        <activity android:name=".activities.RevenueStatActivity" android:exported="false"/>
        <activity android:name=".activities.TopProductStatActivity" android:exported="false"/>
        <activity android:name=".activities.ChangePasswordActivity" android:exported="false"/>

    </application>
</manifest>
